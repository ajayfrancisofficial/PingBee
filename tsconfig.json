{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,                  //suggested by react-navigation
    "moduleResolution": "bundler",   //suggested by react-navigation
    "types": ["jest"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
